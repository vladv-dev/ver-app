# Copy to .env.local for local dev (gitignored). All NEXT_PUBLIC_* vars are
# inlined at build time and shipped to the browser — never put secrets here.

# Durable waitlist capture endpoint (managed form/DB backend).
# Local verification: NEXT_PUBLIC_WAITLIST_ENDPOINT=http://localhost:4000
# Production (static deploy): a managed endpoint, e.g. a Formspree form URL
#   https://formspree.io/f/xxxxxxxx
# When unset, the form stays usable but tells visitors signups aren't live yet.
NEXT_PUBLIC_WAITLIST_ENDPOINT=

# Product name shown in copy/title. Generic until VER-2 picks the wedge.
NEXT_PUBLIC_PRODUCT_NAME=

# Privacy-friendly analytics (Plausible). Set the domain to enable the snippet.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js

# ---------------------------------------------------------------------------
# M2 — auth + payments + entitlements. The app builds and runs without these;
# auth/billing features stay dormant until they are set (see README "M2 setup").
# ---------------------------------------------------------------------------

# Public app URL — used to build Stripe redirect (success/cancel/return) URLs.
# Local: http://localhost:3000 (the default). Prod: your canonical https URL.
NEXT_PUBLIC_APP_URL=

# Supabase (managed Postgres + Auth + Storage). Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service-role key — SERVER ONLY, bypasses RLS. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Stripe. Dashboard → Developers → API keys / Webhooks.
STRIPE_SECRET_KEY=
# Webhook signing secret for /api/stripe/webhook (whsec_...).
STRIPE_WEBHOOK_SECRET=
# Recurring Price IDs (price_...) for each paid plan. Create as GBP/month:
#   Starter £29/mo, Pro £79/mo.
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
