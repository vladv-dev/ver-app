# Copy to .env.local for local dev (gitignored). All NEXT_PUBLIC_* vars are
# inlined at build time and shipped to the browser — never put secrets here.

# Durable waitlist capture endpoint (managed form/DB backend).
# Local verification: NEXT_PUBLIC_WAITLIST_ENDPOINT=http://localhost:4000
# Production (static deploy): a managed endpoint, e.g. a Formspree form URL
#   https://formspree.io/f/xxxxxxxx
# When unset, the form stays usable but tells visitors signups aren't live yet.
NEXT_PUBLIC_WAITLIST_ENDPOINT=

# Product name shown in copy/title. Generic until VER-2 picks the wedge.
NEXT_PUBLIC_PRODUCT_NAME=

# Privacy-friendly analytics (Plausible). Set the domain to enable the snippet.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_PLAUSIBLE_SRC=https://plausible.io/js/script.js
